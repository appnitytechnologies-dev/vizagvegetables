EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth — get from console.cloud.google.com → Credentials
# Android: create "Android" OAuth Client ID (use your app's package name)
# iOS: create "iOS" OAuth Client ID (use your bundle ID)
# For Expo Go testing: create "Web application" client ID and add
#   https://auth.expo.io/@your-expo-username/VizagVegetables as Authorized redirect URI
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
